FROM claude-code-sandbox:latest

USER root

# JRE (for acli) + Go toolchain (for building/testing Go projects)
ARG GO_VERSION=1.23.4
RUN apt-get update && \
    apt-get install -y --no-install-recommends openjdk-21-jre-headless && \
    rm -rf /var/lib/apt/lists/*

RUN GOARCH=$([ "$(uname -m)" = "aarch64" ] && echo "arm64" || echo "amd64") && \
    curl -fsSL "https://go.dev/dl/go${GO_VERSION}.linux-${GOARCH}.tar.gz" \
        | tar -C /usr/local -xz
ENV PATH="/usr/local/go/bin:${PATH}"

# acli — Atlassian CLI (standalone binary)
ARG TARGETARCH
RUN ACLI_ARCH=$([ "$TARGETARCH" = "arm64" ] && echo "arm64" || echo "amd64") && \
    curl -fsSL "https://acli.atlassian.com/linux/latest/acli_linux_${ACLI_ARCH}/acli" \
        -o /usr/local/bin/acli && \
    chmod +x /usr/local/bin/acli

# Inject fix rules into every agent context
COPY docker/ads-fix-rules.md /agent/fix-rules.md

USER agent
