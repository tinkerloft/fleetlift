{
  "plansDirectory": "./docs/plans",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "cd $(git rev-parse --show-toplevel) && go build ./... 2>&1 | head -20"
          }
        ]
      }
    ]
  }
}
